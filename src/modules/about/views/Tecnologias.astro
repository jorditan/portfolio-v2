---
import { SquareMousePointer } from "lucide-react";
import TecnologyCard from "../components/TecnologyCard.astro";
import ReactIcon from "@/assets/icons/astro/ReactIcon.astro";
import VueIcon from "@/assets/icons/astro/VueIcon.astro";
import JavascriptIcon from "@/assets/icons/astro/JavascriptIcon.astro";
import TypescriptIcon from "@/assets/icons/astro/TypescriptIcon.astro";
import PostgreSQL from "@/assets/icons/astro/PostgreSQL.astro";
import PythonIcon from "@/assets/icons/astro/PythonIcon.astro";
import CssIcon from "@/assets/icons/astro/CssIcon.astro";
import JavaIcon from "@/assets/icons/astro/JavaIcon.astro";
import TailwdindIcon from "@/assets/icons/astro/TailwindIcon.astro";
import SassIcon from "@/assets/icons/astro/SassIcon.astro";
import FigmaIcon from "@/assets/icons/astro/FigmaIcon.astro";
import IllustratorIcon from "@/assets/icons/astro/IllustratorIcon.astro";
import PhotoshopIcon from "@/assets/icons/astro/PhotoshopIcon.astro";
import AstroIcon from "@/assets/icons/astro/AstroIcon.astro";
import MiroIcon from "@/assets/icons/astro/MiroIcon.astro";
import ClaudeIcon from "@/assets/icons/astro/claudeIcon.astro";
import BoltIcon from "@/assets/icons/astro/BoltIcon.astro";
import V0Icon from "@/assets/icons/astro/v0Icon.astro";
import SectionHeader from "@/common/components/astroComponentes/SectionHeader.astro";
---

<article
	class="mt-8"
	data-reveal-item
	style="--motion-delay: 40ms; --motion-duration: var(--motion-duration-fast); --motion-distance: 14px;"
>
	<div>
		<SectionHeader title="Herramientas que manejo" size="sm">
			<SquareMousePointer slot="icon" className="text-sky-500 dark:text-sky-300 h-6 w-6" />
		</SectionHeader>
		<div class="flex flex-wrap w-full gap-[16px] md:gap-4 justify-center">
			<TecnologyCard tooltip="Figma">
				<FigmaIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Miro">
				<MiroIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Photoshop">
				<PhotoshopIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Illustrator">
				<IllustratorIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="React">
				<ReactIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Vue">
				<VueIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Astro">
				<AstroIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Javascript">
				<JavascriptIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Typescript">
				<TypescriptIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="PostgreSQL">
				<PostgreSQL slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Java">
				<JavaIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Python">
				<PythonIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Tailwind">
				<TailwdindIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="CSS">
				<CssIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Sass">
				<SassIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="v0">
				<V0Icon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Bolt">
				<BoltIcon slot="icon" />
			</TecnologyCard>

			<TecnologyCard tooltip="Claude">
				<ClaudeIcon slot="icon" />
			</TecnologyCard>
		</div>
	</div>
</article>
