---
import { Code, PenTool } from "lucide-react";

const { title, image, url, type } = Astro.props;
---

<article
	class="group flex h-full flex-col overflow-hidden rounded-md m-2 border border-slate-200 dark:border-white/10 bg-gray-100 dark:bg-gray-800 shadow-md shadow-slate-300/60 dark:shadow-black/30 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-sky-400/70 dark:hover:border-slate-50 hover:shadow-lg hover:shadow-slate-300/70 dark:hover:shadow-black/40"
>
  <a href={url} target="_blank" rel="noopener noreferrer" aria-label={`${title} (se abre en nueva pestaña)`}>
    <div
      class="aspect-[16/9] overflow-hidden border-b border-slate-200/80 bg-slate-100 dark:border-white/10 dark:bg-slate-900/70"
    >
      <img
        src={image}
        class="h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-[1.03]"
        alt={title}
        loading="lazy"
      />
    </div>
  
    <div class="flex flex-1 flex-col gap-2 p-3">
      <div class="flex flex-col gap-2 h-unset">
        <h3
          class="ui-text-card-title truncate text-slate-900 dark:text-slate-100"
        >
          {title}
        </h3>

        {type === "design" ? (
            <span class="text-xs flex items-center border border-sky-500 gap-2  bg-sky-100 dark:bg-sky-800 dark:text-sky-200 p-1 w-fit rounded-md  text-sky-500 font-medium">
              <PenTool className="h-3 w-3" />
              Diseño</span>
          ) : (
            <span class="text-xs flex items-center border border-green-500 gap-2 bg-green-100 dark:bg-green-800 dark:text-green-300 p-1 w-fit rounded-md  text-green-500 font-medium">
              <Code className="h-3 w-3" />
              Desarrollo</span>
          ) 
        }
  
      </div>
    </div>
  </a>
</article>
