---
import StatusBadge from "@/common/components/astroComponentes/StatusBadge.astro";
import SocialIconLink from "@/common/components/astroComponentes/SocialIconLink.astro";
---

<section
	class="sm:mx-auto pt-20 sm:pt-28 py-16 lg:py-22 mx-4 max-w-[32rem] md:max-w-[42rem] lg:max-w-4xl"
	id="inicio"
	data-motion-hero
>
	<article
		class="flex flex-col  gap-4 md:gap-8 justify-center w-fit"
		aria-label="Bienvenida al portfolio"
	>
		<div class="flex flex-col gap-2 md:gap-4" data-motion="hero-item" style="--motion-delay: 60ms; --motion-duration: var(--motion-duration-fast); --motion-distance: 12px;">
			<div class="flex md:gap-4 md:flex-row items-left z-0 md:items-end">
				<div class="flex gap-4 items-center">
					<div
						data-motion="hero-static-word"
						style="--motion-delay: 120ms;"
					>
						<h1
							class="title text-5xl md:text-5xl lg:text-7xl font-bold w-fit text-[#0f172a] dark:text-[#fafafa]"
						>
							Matías
							<span class="selected-word">
								<span class="selected-bg"></span>
								<span class="selected-text">Jordán</span>
							</span>
						</h1>
					</div>
				</div>
				<StatusBadge
					class="m-2 dark:bg-green-900 dark:text-green-200 bg-green-200 hidden md:visible badge gap-2 animate-pulse h-fit md:inline-flex items-center px-2.5 py-0.5 w-fit rounded-md me-2 border border-green-800 dark:border-green-500 transition-all hover:bg-green-300 hover:text-green-900 cursor-not-allowed text-green-800 dark:hover:bg-green-700"
					data-motion="hero-item"
					style="--motion-delay: 180ms; --motion-duration: var(--motion-duration-fast); --motion-distance: 12px;"
				/>
			</div>
			<div
				class="puestos"
				data-motion="hero-item"
				style="--motion-delay: 180ms; --motion-duration: var(--motion-duration-base); --motion-distance: 16px;"
			>
				<div class="roles">
					<h2
						class="text-xl md:text-3xl font-bold w-fit text-[#0f172a] dark:text-[#fafafa]"
					>
						Diseñador UX/UI 🎨
					</h2>
					<h2
						class="text-xl md:text-3xl font-bold w-fit text-[#0f172a] dark:text-[#fafafa]"
					>
						Desarrollador frontend 👨‍💻
					</h2>
				</div>
			</div>
			<StatusBadge
				class="bg-green-200 dark:bg-[#46b1e238] visible md:hidden badge gap-2 animate-pulse text-green-800 dark:text-[#fafafa] h-fit inline-flex items-center px-2.5 py-0.5 w-fit rounded-md border border-green-700 dark:border-gray-500 transition-all hover:bg-green-300 dark:hover:bg-green-900/30"
				data-motion="hero-item"
				style="--motion-delay: 220ms; --motion-duration: var(--motion-duration-fast); --motion-distance: 12px;"
			/>
		</div>
		<p
			class="ui-text-lead text-[#141a28] dark:text-gray-200 w-fit lg:w-[90%]"
			data-motion="hero-item"
			style="--motion-delay: 280ms; --motion-duration: var(--motion-duration-base); --motion-distance: 18px; --motion-blur: var(--motion-blur-sm);"
		>
			<b class="dark:text-sky-300 text-sky-500">+2 años de experiencia</b> diseñando y desarrollando productos digitales.
		</p>

		<div
			class="flex"
			data-motion="hero-item"
			style="--motion-delay: 360ms; --motion-duration: var(--motion-duration-base); --motion-distance: 16px;"
		>
			<SocialIconLink href="https://www.linkedin.com/in/matias-jordan/" label="LinkedIn" icon="linkedin" />
			<SocialIconLink href="https://github.com/jorditan" label="GitHub" icon="github" />
			<SocialIconLink href="https://www.behance.net/matiasowenjordan" label="Behance" icon="behance" />
		</div>
	</article>
</section>

<style scoped>
	@import url("https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&family=Lora:ital,wght@0,400..700;1,400..700&family=Parkinsans:wght@300..800&family=Righteous&display=swap");

	.puestos {
		overflow: hidden;
	}

	.roles,
	h2 {
		list-style: none;
	}
	.roles {
		position: relative;
		height: 36px;
		animation: slide 5s cubic-bezier(0.2, -0.2, 0.1, 1) infinite;
	}

	h2 {
		position: absolute;
	}
	h2:first-child {
		top: 100%;
	}

	h2:last-child {
		top: 300%;
	}

	@keyframes slide {
		0% {
			transform: translateY(0);
		}
		15%,
		30% {
			transform: translateY(-100%);
		}
		45%,
		60% {
			transform: translateY(-300%);
		}
		100% {
			transform: translateY(-100%);
		}
	}

	.icon {
		@apply text-slate-50;
	}

	.badge {
		backdrop-filter: blur(5px);
	}
	.selected-word {
		position: relative;
		display: inline-block;
	}

	.selected-bg {
		position: absolute;
		inset: 80% 0 5% 0;
		background: oklch(68.5% 0.169 237.323);
		transform: scaleX(0);
		transform-origin: left;
		animation: selectWord 700ms ease-out 300ms forwards;
		border-radius: 8px;
	}

	.selected-text {
		position: relative;
		z-index: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.roles {
			animation: none;
			height: auto;
			display: flex;
			flex-direction: column;
			gap: 0.25rem;
		}

		h2 {
			position: static;
		}

		.selected-bg {
			transform: scaleX(1);
			animation: none;
		}

		.badge {
			animation: none;
		}
	}

	@keyframes selectWord {
		to {
			transform: scaleX(1);
		}
	}
</style>
