---
const { title, date, description, place, url, img, order = 0, datetime } = Astro.props;
---

<li
	class="relative mb-4 ms-4"
	data-reveal-item
	style={`--motion-delay: ${120 + order * 90}ms; --motion-duration: var(--motion-duration-base); --motion-distance: 16px; --motion-blur: 4px;`}
>
	<div
		class="absolute top-1.5 left-[-22px] w-3 h-3 bg-sky-600 rounded-full -start-1.5 border border-white dark:border-gray-900 dark:bg-sky-300"
	>
	</div>

	<div class="flex items-center gap-4 pb-1">
		<img
			src={img}
			class="object-cover p-1 border border-slate-50/45 rounded-xl h-10 w-10"
			alt={`${title} Logo`}
		/>
		<div class="flex gap-1 flex-col w-full">
			<div class="flex items-center">
				<time
					class="text-sm font-normal leading-none text-gray-800 dark:text-gray-300"
					datetime={datetime ?? date}
					>{date}</time
				>
			</div>
			<div class="flex gap-2 items-center pb-1">
				<h3
					class="ui-text-card-title truncate text-gray-900 dark:text-gray-100"
				>
					<a
						href={url}
						target="_blank"
						rel="noopener noreferrer"
						class="hover:text-sky-500 dark:hover:text-sky-300 hover:underline cursor-pointer transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-1 rounded-sm"
					>
						{title}
					</a>
				</h3>
			</div>
		</div>
	</div>

	<div class="pb-4 flex flex-col gap-4 pt-2">
		<small class="ui-text-caption text-gray-800 dark:text-gray-300">
			Trabajando en {place} logré:
		</small>
		<ol class="pl-4 flex flex-col gap-2">
			{
				description.map((item: string) => (
					<li class="text-xs sm:text-sm text-gray-800 dark:text-gray-300 list-disc">
						{item}
					</li>
				))
			}
		</ol>
	</div>
</li>
