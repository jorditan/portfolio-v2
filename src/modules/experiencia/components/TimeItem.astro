---
const { title, date, description, url, img } = Astro.props;
---

<li class="mb-4 ms-4">
	<div
		class="absolute w-3 h-3 bg-sky-600 rounded-full mt-1.5 -start-1.5 border border-white dark:border-gray-900 dark:bg-sky-500"
	>
	</div>

	<div class="flex items-center gap-4 pb-1">
		<img
			src={img}
			class="object-cover p-1 border border-slate-50/45 rounded-xl h-10 w-10"
			alt={title + " Logo"}
		/>

		<div class="flex gap-1 flex-col w-full">
			<div class="flex gap-2 items-center mb-1">
				<time
					class="text-sm font-normal leading-none text-gray-800 dark:text-gray-300"
					>{date}</time
				>
			</div>
			<div class="flex gap-4 items-center pb-1">
				<h3
					class="md:text-lg text-[14px] truncate font-semibold text-gray-900 dark:text-gray-100"
				>
				<a href={url} target="_blank" class="hover:text-sky-500 dark:hover:text-sky-300 hover:underline hover:scale-110 cursor-pointer dark:hover:text-sky-40 transition-colors duration-200">
					{title}
				</a>
				</h3>
			</div>
		</div>
	</div>

	<div class="pb-4">
		<ol class="pl-4 flex flex-col gap-2">
			{
				description.map((item: string) => (
					<li class="text-xs sm:text-sm text-gray-800 dark:text-gray-300 list-disc">
						{item}
					</li>
				))
			}
		</ol>
	</div>
</li>
