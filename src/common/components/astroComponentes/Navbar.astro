---
import { Download } from "lucide-react";
import ThemeSelector from "../reactComponentes/ThemeSelector";
---

<header class="flex justify-center py-5 fixed w-full z-10">
	<nav
		class="py-1 sm:py-2 px-4 dark:bg-black/10 bg-sky-200/44 flex glass justify-center rounded-lg transition-all gap-12 items-center border-2 dark:border-white/20 dark:hover:border-white/30 border-slate-500"
	>
		<div class="flex gap-4 sm:gap-8 items-center justify-center">
			<ul class="flex gap-4">
				<li>
					<a
						href="/#inicio"
						class="pointer text-slate-900 dark:text-slate-50 text-[12px] sm:text-[16px] decoration-none cursor-pointer hover:text-sky-600 dark:hover:text-sky-400 transition-all"
					>
						Inicio
					</a>
				</li>
				<li>
					<a
						href="/#proyectos"
						class="pointer text-slate-900 dark:text-slate-50 text-[12px] sm:text-[16px] decoration-none cursor-pointer hover:text-sky-600 dark:hover:text-sky-400 transition-all"
					>
						Proyectos
					</a>
				</li>
				<li>
					<a
						href="/#sobreMi"
						class="pointer text-slate-900 dark:text-slate-50 text-[12px] sm:text-[16px] decoration-none cursor-pointer hover:text-sky-600 dark:hover:text-sky-400 transition-all"
					>
						Sobre mi
					</a>
				</li>
				<li>
					<a
						data-astro-prefetch="hover"
						href="#contacto"
						class="pointer text-slate-900 dark:text-slate-50 text-[12px] sm:text-[16px] decoration-none cursor-pointer hover:text-sky-600 dark:hover:text-sky-400 transition-all"
					>
						Contacto
					</a>
				</li>
			</ul>

			<div class="flex gap-2 sm:gap-4 items-center">
				<ThemeSelector client:only="react" />
				<div
					id="tooltip-cv"
					role="tooltip"
					class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-slate-50 dark:text-gray-900 bg-slate-900 dark:bg-white border dark:border-gray-200 rounded-lg shadow-sm opacity-0 tooltip"
				>
					Descargar CV
					<div class="tooltip-arrow" data-popper-arrow></div>
				</div>
				<button
					id="descargacv"
					aria-labelledby="Descarga de CV"
					aria-label="DownloadButton"
					data-tooltip-target="tooltip-cv"
					class="rounded-full"
					name="Descargador de CV"
				>
					<a
						download
						href="/curriculum_vitae.pdf"
						class="w-fit h-fit"
						target="_blank"
						aria-label="Download button"
					>
						<Download
							className="icon transition-all hover:scale-110 stroke-slate-900 dark:stroke-slate-50 h-[16px] w-[16px] sm:h-[24px] sm:w-[24px]"
						/>
					</a>
				</button>
			</div>
		</div>
	</nav>
</header>

<style scoped>
	.glass {
		backdrop-filter: blur(10px);
		position: relative;
	}
	.icon {
		color: theme("colors.slate.50");
	}
</style>
