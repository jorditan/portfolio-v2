---
import { Download } from "lucide-react";
import ThemeSelector from "../reactComponentes/ThemeSelector";
---

<header class="fixed inset-x-0 top-0 z-40 md:hidden">
	<div class="flex items-center justify-between gap-2 px-3 pt-3">
		<!-- Izquierda: botón hamburger -->
		<button
			id="menu-toggle"
			aria-label="Abrir menú de navegación"
			aria-expanded="false"
			aria-controls="mobile-nav-menu"
			class="flex items-center justify-center h-11 w-11 rounded-[14px]
             border border-slate-300/60 dark:border-white/20
             bg-gray-100/80 dark:bg-black/50
             backdrop-blur-xl shadow-sm
             text-slate-800 dark:text-slate-100
             transition-all duration-200 active:scale-90 active:opacity-70"
		>
			<!-- Burger icon -->
			<svg
				id="icon-burger"
				xmlns="http://www.w3.org/2000/svg"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<line x1="4" y1="7" x2="20" y2="7"></line>
				<line x1="4" y1="12" x2="20" y2="12"></line>
				<line x1="4" y1="17" x2="20" y2="17"></line>
			</svg>
			<!-- X icon (oculto por defecto) -->
			<svg
				id="icon-x"
				xmlns="http://www.w3.org/2000/svg"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2.5"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
				class="hidden"
			>
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>

		<!-- Derecha: tema + CV -->
		<div
			class="flex items-center gap-1 px-2 h-11 rounded-[14px]
             border border-slate-300/60 dark:border-white/20
             bg-gray-100/80 dark:bg-black/50
             backdrop-blur-xl shadow-sm"
		>
			<ThemeSelector client:only="react" />
			<div class="w-px h-5 bg-slate-300/80 dark:bg-gray-100/20 mx-1"></div>
			<a
				download
				href="/docs/curriculum_vitae.pdf"
				target="_blank"
				aria-label="Descargar curriculum vitae en PDF"
				class="flex items-center justify-center h-8 w-8 rounded-xl
               text-slate-700 dark:text-slate-200
               hover:text-sky-600 dark:hover:text-sky-400
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500
               transition-colors"
			>
				<Download className="h-[17px] w-[17px]" />
			</a>
		</div>
	</div>
</header>

<!-- ── MOBILE: panel del menú ──────────────────────────────────────── -->
<div
	id="mobile-nav-menu"
	role="dialog"
	aria-modal="true"
	aria-label="Menú de navegación"
	class="md:hidden fixed top-[4.25rem] left-3 right-3 z-40
         rounded-2xl overflow-hidden
         border border-white/30 dark:border-white/15
         bg-gray-100/60 dark:bg-slate-900/70
         backdrop-blur-2xl backdrop-saturate-150
         shadow-xl shadow-black/10 dark:shadow-black/40
         opacity-0 -translate-y-2 scale-[0.97] pointer-events-none
         transition-all duration-300 ease-out origin-top-left"
>
	<nav>
		<ul
			class="flex flex-col divide-y divide-slate-900/10 dark:divide-white/10 py-1"
		>
			<li>
				<a href="/#inicio" class="nav-mobile-item">
					<span>Inicio</span>
				</a>
			</li>
			<li>
				<a href="/#proyectos" class="nav-mobile-item">
					<span>Proyectos</span>
				</a>
			</li>
			<li>
				<a href="/#sobreMi" class="nav-mobile-item">
					<span>Sobre mí</span>
				</a>
			</li>
			<li>
				<a href="#contacto" class="nav-mobile-item">
					<span>Contacto</span>
				</a>
			</li>
		</ul>
	</nav>
</div>

<!-- ── MOBILE: backdrop para cerrar al tocar afuera ───────────────── -->
<div
	id="menu-backdrop"
	class="md:hidden fixed inset-0 z-30
         bg-black/20 dark:bg-black/40
         opacity-0 pointer-events-none
         transition-opacity duration-300"
>
</div>

<!-- ── DESKTOP: píldora centrada (≥ md) ───────────────────────────── -->
<header
	class="hidden md:flex fixed inset-x-0 top-0 z-40 justify-center px-3 py-5"
>
	<nav
		class="glass w-fit rounded-2xl border-2 border-slate-500 bg-sky-200/45 px-3 py-1
           transition-all dark:border-white/20 dark:bg-black/10 dark:hover:border-white/30
           sm:mx-auto sm:inline-flex sm:w-auto sm:px-4"
	>
		<div
			class="flex w-fit items-center justify-center gap-4 sm:w-auto sm:flex-row sm:gap-x-6 lg:gap-x-8"
		>
			<ul class="flex items-center gap-x-4 md:gap-x-6">
				<li>
					<a href="/#inicio" class="nav-link-desktop">Inicio</a>
				</li>
				<li>
					<a href="/#proyectos" class="nav-link-desktop">Proyectos</a>
				</li>
				<li>
					<a href="/#sobreMi" class="nav-link-desktop">Sobre mi</a>
				</li>
				<li>
					<a href="#contacto" class="nav-link-desktop">Contacto</a>
				</li>
			</ul>

			<div class="flex items-center gap-2 sm:gap-4">
				<ThemeSelector client:only="react" />
				<a
					download
					href="/docs/curriculum_vitae.pdf"
					target="_blank"
					aria-label="Descargar curriculum vitae en PDF"
					class="flex h-11 w-11 items-center justify-center rounded-full
					       border border-slate-500/70 dark:border-white/20
					       text-slate-900 dark:text-slate-50
					       transition-all hover:scale-105 hover:text-sky-600 dark:hover:text-sky-400
					       focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500"
				>
					<Download className="h-[16px] w-[16px] sm:h-[18px] sm:w-[18px]" />
				</a>
			</div>
		</div>
	</nav>
</header>

<script>
	function setupMobileMenu() {
		const toggle = document.getElementById("menu-toggle");
		const menu = document.getElementById("mobile-nav-menu");
		const backdrop = document.getElementById("menu-backdrop");
		const iconBurger = document.getElementById("icon-burger");
		const iconX = document.getElementById("icon-x");

		if (!toggle || !menu || !backdrop) return;

		let isOpen = false;

		function openMenu() {
			isOpen = true;
			// Panel
			menu.classList.remove(
				"opacity-0",
				"-translate-y-2",
				"scale-[0.97]",
				"pointer-events-none",
			);
			menu.classList.add("opacity-100", "translate-y-0", "scale-100");
			// Backdrop
			backdrop.classList.remove("opacity-0", "pointer-events-none");
			backdrop.classList.add("opacity-100", "pointer-events-auto");
			// Iconos
			iconBurger?.classList.add("hidden");
			iconX?.classList.remove("hidden");
			toggle.setAttribute("aria-expanded", "true");
		}

		function closeMenu() {
			isOpen = false;
			menu.classList.add(
				"opacity-0",
				"-translate-y-2",
				"scale-[0.97]",
				"pointer-events-none",
			);
			menu.classList.remove("opacity-100", "translate-y-0", "scale-100");
			backdrop.classList.add("opacity-0", "pointer-events-none");
			backdrop.classList.remove("opacity-100", "pointer-events-auto");
			iconBurger?.classList.remove("hidden");
			iconX?.classList.add("hidden");
			toggle.setAttribute("aria-expanded", "false");
		}

		toggle.addEventListener("click", () => (isOpen ? closeMenu() : openMenu()));
		backdrop.addEventListener("click", closeMenu);
		menu
			.querySelectorAll("a")
			.forEach((link) => link.addEventListener("click", closeMenu));
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && isOpen) closeMenu();
		});
	}

	// Compatible con Astro View Transitions
	document.addEventListener("astro:page-load", setupMobileMenu);
	if (document.readyState !== "loading") {
		setupMobileMenu();
	} else {
		document.addEventListener("DOMContentLoaded", setupMobileMenu);
	}
</script>

<style>
	.glass {
		backdrop-filter: blur(10px);
		position: relative;
	}

	.nav-link-desktop {
		@apply cursor-pointer text-sm text-slate-900 transition-all
           hover:text-sky-600 dark:text-slate-50 dark:hover:text-sky-400
           md:text-base;
	}

	.nav-mobile-item {
		@apply flex items-center justify-between
           px-5 py-[15px] min-h-[54px]
           text-[1rem] font-semibold
           text-slate-900 dark:text-white
           hover:bg-black/5 dark:hover:bg-gray-100/10
           active:bg-black/10 dark:active:bg-gray-100/15
           focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-sky-500
           transition-colors duration-150
           select-none;
	}
</style>
