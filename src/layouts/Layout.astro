---
import Footer from "@/common/components/astroComponentes/Footer.astro";
import Navbar from "@/common/components/astroComponentes/Navbar.astro";
import { ClientRouter } from "astro:transitions";
import ThemeCabezaScript from "./theme-cabeza-script.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
---

<!doctype html>
<html
	lang="en"
	transition:persist="header"
	class="scroll-smooth focus:scroll-auto"
>
	<head>
		<script is:inline>
			document.documentElement.classList.add("js");
		</script>
		<ThemeCabezaScript />
		<SpeedInsights />
		<meta charset="UTF-8" />
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Portfolio web de Matías Owen Jordán, product designer y desarrollador frontend"
		/>
		<meta
			name="keywords"
			content="Vue, React, CSS, JavaScript, Astro, Figma, Product Designer, Frontend"
		/>
		<meta name="author" content="Matías Owen Jordán" />
		<meta
			property="og:title"
			content="Matías – Diseñador de Producto y Programador"
		/>
		<meta
			property="og:description"
			content="Soy Matías, diseñador de producto y programador. Combino UX/UI con código para crear experiencias digitales funcionales."
		/>
		<meta
			property="og:image"
			content="https://https://matias-jordan-portfolio.netlify.app/foto-campo"
		/>
		<meta
			property="og:url"
			content="https://matias-jordan-portfolio.netlify.app"
		/>
		<meta property="og:type" content="website" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="canonical"
			href={`https://https://matias-jordan-portfolio.netlify.app/${Astro.url.pathname}`}
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/palette.svg" />
		<title>Matías Owen Jordán</title>
	</head>
	<body data-cursor-glow>
		<ClientRouter />
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />
		<script
			is:inline
			src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"
		></script>
		<script is:inline>
			(() => {
				const config = {
					heroVisibleDelay: 50,
					observerThreshold: 0.18,
					observerRootMargin: "0px 0px -10% 0px",
					cursorFade: 0.16,
				};

				const state = {
					observer: null,
					mutationObserver: null,
					cursorCleanup: [],
				};

				const selectors = '[data-motion="hero-item"], [data-reveal-item]';

				const revealElement = (element) => {
					if (!element || element.classList.contains("is-visible")) return;
					element.classList.add("is-visible");
				};

				const revealAll = (root = document) => {
					root.querySelectorAll(selectors).forEach(revealElement);
				};

				const setupHero = () => {
					const hero = document.querySelector("[data-motion-hero]");
					if (!hero || hero.dataset.motionBound === "true") return;

					hero.dataset.motionBound = "true";

					window.setTimeout(() => {
						hero.querySelectorAll('[data-motion="hero-item"]').forEach(revealElement);
					}, config.heroVisibleDelay);
				};

				const setupObserver = () => {
					if (!("IntersectionObserver" in window)) {
						revealAll();
						return;
					}

					if (!state.observer) {
						state.observer = new IntersectionObserver(
							(entries) => {
								entries.forEach((entry) => {
									if (!entry.isIntersecting) return;
									revealElement(entry.target);
									state.observer?.unobserve(entry.target);
								});
							},
							{
								threshold: config.observerThreshold,
								rootMargin: config.observerRootMargin,
							},
						);
					}

					document.querySelectorAll("[data-reveal-item]").forEach((element) => {
						if (element.dataset.revealBound === "true" || element.classList.contains("is-visible")) return;
						element.dataset.revealBound = "true";
						state.observer?.observe(element);
					});
				};

				const setupCursorGlow = () => {
					state.cursorCleanup.forEach((cleanup) => cleanup());
					state.cursorCleanup = [];

					if (window.matchMedia("(hover: none), (pointer: coarse), (max-width: 767px)").matches) {
						return;
					}

					document.querySelectorAll("[data-cursor-glow]").forEach((element) => {
						if (element.dataset.cursorBound === "true") return;
						element.dataset.cursorBound = "true";

						const updatePosition = (event) => {
							const rect = element.getBoundingClientRect();
							const x = ((event.clientX - rect.left) / rect.width) * 100;
							const y = ((event.clientY - rect.top) / rect.height) * 100;

							element.style.setProperty("--cursor-x", `${Math.max(0, Math.min(100, x))}%`);
							element.style.setProperty("--cursor-y", `${Math.max(0, Math.min(100, y))}%`);
							element.style.setProperty("--cursor-opacity", `${config.cursorFade}`);
						};

						const resetPosition = () => {
							element.style.setProperty("--cursor-opacity", "0");
						};

						element.addEventListener("pointermove", updatePosition, { passive: true });
						element.addEventListener("pointerleave", resetPosition, { passive: true });

						state.cursorCleanup.push(() => {
							element.removeEventListener("pointermove", updatePosition);
							element.removeEventListener("pointerleave", resetPosition);
							element.dataset.cursorBound = "false";
						});
					});
				};

				const initMotion = () => {
					const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
					document.documentElement.classList.toggle("motion-enabled", !reduceMotion);

					if (reduceMotion) {
						if (state.observer) state.observer.disconnect();
						revealAll();
						return;
					}

					setupHero();
					setupObserver();
					setupCursorGlow();
				};

				const observeDom = () => {
					if (state.mutationObserver) state.mutationObserver.disconnect();

					state.mutationObserver = new MutationObserver(() => {
						window.requestAnimationFrame(() => {
							setupHero();
							setupObserver();
							setupCursorGlow();
						});
					});

					state.mutationObserver.observe(document.body, {
						childList: true,
						subtree: true,
					});
				};

				document.addEventListener("astro:page-load", () => {
					initMotion();
					observeDom();
				});

				if (document.readyState !== "loading") {
					initMotion();
					observeDom();
				} else {
					document.addEventListener(
						"DOMContentLoaded",
						() => {
							initMotion();
							observeDom();
						},
						{ once: true },
					);
				}
			})();
		</script>

		<script type="application/ld+json">
			{
				"@context": "http://schema.org",
				"@type": "Dataset",
				"name": "Portfolio de Matías Jordán",
				"description": "Product Designer y desarrollador Front-End de 20 años. Apasionado en el desarrollo y diseño de soluciones innovadoras. Estudiante de la Licenciatura en Informática en la Universidad Nacional de Hurlingham (UNAHUR)."
			}
		</script>
	</body>
</html>

<style is:global>
	html,
	body {
		font-family: "Parkinsans", sans-serif;
		font-optical-sizing: auto;
		margin: 0;
	}

	html {
		scroll-padding-top: 6rem;
	}

	main {
		margin: 0;
	}
	:root {
		color-scheme: dark light;
		--text-color: #f8fafc;
	}

	.dark body {
		background-image: linear-gradient(
			to right bottom,
			#071e40,
			#16243c,
			#0e2758,
			#16243c,
			#102053
		);
	}

	body {
		background-image: linear-gradient(
			to right bottom,
			#fafafa,
			#f3f4fc,
			#e9f0fe,
			#dcecff,
			#cbe9ff,
			#c2e8ff,
			#b8e6ff,
			#aee5fe,
			#ade5fe,
			#ace4fd,
			#aae4fd,
			#a9e3fc
		);
	}

	body::before {
		content: "";
		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		background-image:
			url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 0H0V40' stroke='%23000000' stroke-opacity='0.04'/%3E%3C/svg%3E"),
			radial-gradient(
				circle at 50% 30%,
				rgba(255, 255, 255, 0.08),
				transparent 70%
			);
		background-repeat: repeat, no-repeat;
		background-size:
			40px 40px,
			cover;
		background-blend-mode: overlay;
	}

	html.dark body::before {
		background-image:
			url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 0H0V40' stroke='%23ffffff' stroke-opacity='0.04'/%3E%3C/svg%3E"),
			radial-gradient(
				circle at 50% 30%,
				rgba(255, 255, 255, 0.08),
				transparent 70%
			);
		background-blend-mode: lighten;
	}
	::-webkit-scrollbar {
		width: 5px;
	}
	::-webkit-scrollbar-track {
		background: #071e40;
	}

	::-webkit-scrollbar-thumb {
		background-color: #38bdf8;
		border-radius: 10px;
	}
</style>
